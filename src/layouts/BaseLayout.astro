---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;

const siteUrl = Astro.site?.href ?? 'https://boomdev.com/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Boomdev',
  url: siteUrl,
  description:
    'A small home for independent software initiatives, practical tools, AI experiments, and business software projects.',
};
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link
      href="https://fonts.bunny.net/css?family=bricolage-grotesque:500,600,700|source-sans-3:400,500,600&display=swap"
      rel="stylesheet"
    />
    <SEO title={title} description={description} canonical={canonical} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
