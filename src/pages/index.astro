---
import BaseLayout from '../layouts/BaseLayout.astro';
import ValueList from '../components/ValueList.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TallyEmbed from '../components/TallyEmbed.astro';
import { values } from '../data/values';
import { projects } from '../data/projects';
---

<BaseLayout
  title="Boomdev | Independent software projects and AI experiments"
  description="An index of independent software projects, experiments, and tools under the Boomdev umbrella."
  canonical="https://boomdev.com/"
>
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container hero__inner">
      <h1 id="hero-heading" class="hero__title">
        Practical software projects, <span class="hero__emphasis">built independently.</span>
      </h1>
      <p class="hero__subtitle">
        An index of independent tools, experiments, and sites. Each project has its own home;
        this page is how you find them.
      </p>
      <p class="hero__actions">
        <a href="#projects" class="btn btn--primary">View projects</a>
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="about-heading">
    <div class="container">
      <h2 id="about-heading" class="section__title">What is Boomdev?</h2>
      <div class="prose">
        <p>
          Boomdev is an umbrella for independent software work: live products, prototypes, and
          research notes. Each initiative has its own site and status.
        </p>
        <p>
          This is not a single company with one product line. The goal is a clear map of what
          exists, without inventing scale or authority the work does not have.
        </p>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="values-heading">
    <div class="container">
      <h2 id="values-heading" class="section__title">Principles</h2>
      <ValueList items={values} />
    </div>
  </section>

  <section id="projects" class="section section--tinted" aria-labelledby="projects-heading">
    <div class="container">
      <h2 id="projects-heading" class="section__title">Projects</h2>
      {
        projects.length === 0 ? (
          <p class="empty-state" role="status">No projects are listed yet.</p>
        ) : (
          <div class="card-grid card-grid--projects">
            {
              projects.map((project) => (
                <ProjectCard
                  name={project.name}
                  url={project.url}
                  status={project.status}
                  category={project.category}
                  description={project.description}
                />
              ))
            }
          </div>
        )
      }
    </div>
  </section>

  <section id="contact" class="section" aria-labelledby="contact-heading">
    <div class="container">
      <h2 id="contact-heading" class="section__title">Contact</h2>
      <TallyEmbed />
    </div>
  </section>
</BaseLayout>
