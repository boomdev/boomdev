---
import type { ProjectStatus } from '../data/projects';
import { normalizeExternalUrl } from '../utils/url';

interface Props {
  name: string;
  url?: string;
  status: ProjectStatus;
  category: string;
  description: string;
}

const { name, url, status, category, description } = Astro.props;
const safeUrl = normalizeExternalUrl(url);

const statusClassMap: Record<ProjectStatus, string> = {
  Product: 'badge--product',
  Project: 'badge--project',
  Experiment: 'badge--experiment',
  'Research note': 'badge--research',
  'Content project': 'badge--content',
  'AI project': 'badge--ai',
  'Home base': 'badge--home',
};

const badgeClass = statusClassMap[status] ?? 'badge--home';
---

{
  safeUrl ? (
    <a
      href={safeUrl}
      class="card card--link card--project"
      target="_blank"
      rel="noopener noreferrer"
    >
      <h3 class="card__title">
        {name}
        <span class="card__external" aria-hidden="true">↗</span>
        <span class="sr-only"> (opens in new tab)</span>
      </h3>
      <p class="card__description">{description}</p>
      <div class="card__meta">
        <span class:list={['badge', badgeClass]}>{status}</span>
        <span class="tag">{category}</span>
      </div>
    </a>
  ) : (
    <article class="card card--coming-soon">
      <h3 class="card__title">{name}</h3>
      <p class="card__description">{description}</p>
      <div class="card__meta">
        <span class:list={['badge', badgeClass]}>{status}</span>
        <span class="tag">{category}</span>
        <span class="tag">Coming soon</span>
      </div>
    </article>
  )
}
