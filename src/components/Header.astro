---
const navItems = [
  { href: '/#projects', label: 'Projects' },
  { href: '/#contact', label: 'Contact' },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-logo">Boomdev</a>
    <nav aria-label="Main">
      <ul class="site-nav">
        {
          navItems.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
