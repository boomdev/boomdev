---
import { buildTallyEmbedUrl, isContactEmail, isTallyEmbedUrl } from '../utils/url';

const rawTallyUrl = import.meta.env.PUBLIC_TALLY_EMBED_URL?.trim();
const tallyUrl =
  rawTallyUrl && isTallyEmbedUrl(rawTallyUrl) ? rawTallyUrl : undefined;
const tallyEmbedSrc = tallyUrl ? buildTallyEmbedUrl(tallyUrl) : undefined;
const tallyMisconfigured = Boolean(rawTallyUrl && !tallyUrl);

const rawContactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL?.trim();
const contactEmail =
  rawContactEmail && isContactEmail(rawContactEmail) ? rawContactEmail : undefined;
const contactEmailMisconfigured = Boolean(rawContactEmail && !contactEmail);
---

{
  tallyEmbedSrc ? (
    <>
      <div class="tally-wrapper">
        <iframe
          class="tally-embed"
          data-tally-src={tallyEmbedSrc}
          title="Contact form"
          loading="lazy"
          width="100%"
          height="200"
          scrolling="no"
          referrerpolicy="strict-origin-when-cross-origin"
          allow="clipboard-write"
        />
      </div>
      <script is:inline>
        (function () {
          var widgetSrc = 'https://tally.so/widgets/embed.js';

          function loadEmbeds() {
            if (window.Tally) {
              window.Tally.loadEmbeds();
              return;
            }
            document.querySelectorAll('iframe[data-tally-src]:not([src])').forEach(function (el) {
              el.src = el.getAttribute('data-tally-src');
            });
          }

          var existing = document.querySelector('script[src="' + widgetSrc + '"]');
          if (existing) {
            if (window.Tally) {
              loadEmbeds();
            } else {
              existing.addEventListener('load', loadEmbeds);
            }
            return;
          }

          var script = document.createElement('script');
          script.src = widgetSrc;
          script.onload = loadEmbeds;
          script.onerror = loadEmbeds;
          document.body.appendChild(script);
        })();
      </script>
    </>
  ) : tallyMisconfigured ? (
    <div class="tally-error" role="alert">
      <p class="tally-error__title">Contact form could not be loaded</p>
      <p class="tally-error__detail">
        <code>PUBLIC_TALLY_EMBED_URL</code> must be an HTTPS embed URL from{' '}
        <a href="https://tally.so" rel="noopener noreferrer">tally.so</a>.
      </p>
      {
        contactEmail ? (
          <p class="tally-error__fallback">
            You can still reach us at{' '}
            <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.
          </p>
        ) : null
      }
    </div>
  ) : (
    <div class="tally-placeholder" role="status">
      <p>Contact form is not configured yet.</p>
      {
        contactEmail ? (
          <p class="tally-placeholder__hint">
            Email <a href={`mailto:${contactEmail}`}>{contactEmail}</a> or set{' '}
            <code>PUBLIC_TALLY_EMBED_URL</code> in your environment.
          </p>
        ) : (
          <p class="tally-placeholder__hint">
            Set <code>PUBLIC_TALLY_EMBED_URL</code> to your Tally embed URL, or{' '}
            <code>PUBLIC_CONTACT_EMAIL</code> for a mailto fallback.
          </p>
        )
      }
      {
        contactEmailMisconfigured ? (
          <p class="tally-error__detail" role="alert">
            <code>PUBLIC_CONTACT_EMAIL</code> is set but is not a valid email address.
          </p>
        ) : null
      }
    </div>
  )
}
